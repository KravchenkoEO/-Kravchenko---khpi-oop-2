import java.util.Objects;

public abstract class User {
    private final String userId;
    private String username;
    private String password; // У реальних системах паролі не зберігаються у чистому вигляді!

    public User(String userId, String username, String password) {
        if (userId == null || userId.isEmpty()) throw new IllegalArgumentException("User ID cannot be null or empty.");
        if (username == null || username.isEmpty()) throw new IllegalArgumentException("Username cannot be null or empty.");
        this.userId = userId;
        this.username = username;
        this.password = password; // Для прикладу, в реальності - хешування
    }

    public boolean login(String passwordAttempt) {
        return this.password.equals(passwordAttempt); // Для прикладу
    }

    // Getters and setters
    public String getUserId() { return userId; }
    public String getUsername() { return username; }
    // Setter for username, no setter for password (should be changePassword method)

    @Override
    public String toString() {
        return String.format("User[id=%s, username=%s]", userId, username);
    }

    @Override
    public boolean equals(Object o) {
        if (this == o) return true;
        if (o == null || getClass() != o.getClass()) return false;
        User user = (User) o;
        return Objects.equals(userId, user.userId);
    }

    @Override
    public int hashCode() {
        return Objects.hash(userId);
    }
}
