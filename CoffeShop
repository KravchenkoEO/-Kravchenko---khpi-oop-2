import java.util.Objects;

public class OrderItem {
    private final MenuItem item; // Асоціація
    private int quantity;
    private final double priceAtOrder; // Зберігаємо ціну на момент замовлення

    public OrderItem(MenuItem item, int quantity) {
        Objects.requireNonNull(item, "Menu item cannot be null.");
        if (quantity <= 0) throw new IllegalArgumentException("Quantity must be positive.");
        this.item = item;
        this.quantity = quantity;
        this.priceAtOrder = item.getPrice(); // Зберігаємо поточну ціну товару при створенні позиції
    }

    public double getCost() {
        return priceAtOrder * quantity;
    }

    public void addQuantity(int amount) {
        if (amount <= 0) throw new IllegalArgumentException("Amount to add must be positive.");
        this.quantity += amount;
    }

    // Getters
    public MenuItem getItem() { return item; }
    public int getQuantity() { return quantity; }
    public double getPriceAtOrder() { return priceAtOrder; }

    @Override
    public String toString() {
        return String.format("OrderItem[item=%s, qty=%d, priceAtOrder=%.2f, cost=%.2f]",
                item.getName(), quantity, priceAtOrder, getCost());
    }

    // equals and hashCode based on item and priceAtOrder
    @Override
    public boolean equals(Object o) {
        if (this == o) return true;
        if (o == null || getClass() != o.getClass()) return false;
        OrderItem orderItem = (OrderItem) o;
        return Double.compare(orderItem.priceAtOrder, priceAtOrder) == 0 &&
                quantity == orderItem.quantity &&
                Objects.equals(item, orderItem.item);
    }

    @Override
    public int hashCode() {
        return Objects.hash(item, quantity, priceAtOrder);
    }
}
